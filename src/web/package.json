{
  "name": "quorumq",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project app",
    "dev": "ng serve --project app",
    "build": "ng build app && ng build components",
    "watch": "ng build app --watch --configuration development",
    "test": "ng test",
    "generate:api": "npx openapi-typescript http://localhost:5052/openapi/v1.json -o projects/app/src/app/core/api/generated/api.d.ts",
    "analyze": "ng build app --source-map && npx source-map-explorer dist/app/browser/*.js --html dist/app/browser/bundle-report.html"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@microsoft/signalr": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
